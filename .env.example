# ==============================================================
# PsicoSST — Environment Configuration
# Copy to .env and fill in your values
# ==============================================================

# --- Database ---
POSTGRES_USER=psicosst
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=psicosst
DATABASE_URL="postgresql://psicosst:change_me_strong_password@localhost:5432/psicosst?schema=public"

# --- NextAuth.js ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# --- Application ---
NODE_ENV=development
APP_NAME=PsicoSST
APP_LOCALE=es-CO

# --- Security ---
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
BCRYPT_ROUNDS=12

# --- Report Signing ---
# RSA private key path for digital signature (production only)
# SIGNING_KEY_PATH=/etc/psicosst/signing-key.pem
